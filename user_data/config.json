{
  "max_open_trades": 5,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "timeframe": "5m",
  "exchange": {
    "name": "binance",
    "rateLimit": 1200,
    "ccxt_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "BNB/USDT",
      "SOL/USDT",
      "ADA/USDT"
    ]
  },
  "pairlists": [
    {
      "method": "StaticPairList",
      "pairs": [
        "BTC/USDT",
        "ETH/USDT",
        "BNB/USDT",
        "SOL/USDT",
        "ADA/USDT"
      ]
    }
  ],
  "fee": 0.001,
  "enable_order_filled_stoploss": true,
  "unfilledtimeout": {
    "entry": 5,
    "exit": 5,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "bid",
    "price_last_balance": 0.0,
    "use_order_book": true
  },
  "exit_pricing": {
    "price_side": "ask",
    "use_order_book": true
  }
}
